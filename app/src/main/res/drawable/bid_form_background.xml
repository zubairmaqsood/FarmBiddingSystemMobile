<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- This gives the sheet a clean, solid white background -->
    <solid android:color="@color/white" />

    <!-- This rounds ONLY the top two corners so it looks like a sheet sliding up -->
    <corners
        android:topLeftRadius="@dimen/height_24"
        android:topRightRadius="@dimen/height_24" />

</shape>