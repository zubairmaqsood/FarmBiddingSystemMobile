<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="160dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_menu_gallery"
            android:background="#E0E0E0" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Premium Wheat"
                android:textColor="#212121"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Qty: 500 KG"
                android:textColor="#757575"
                android:textSize="12sp"
                android:drawableStart="@drawable/ic_weight"
                android:drawablePadding="6dp"
                android:drawableTint="#8D6E63"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="34 Bids Placed"
                android:textColor="#546E7A"
                android:textSize="12sp"
                android:drawableStart="@drawable/ic_gavel"
                android:drawablePadding="6dp"
                android:drawableTint="#1976D2"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="4d 3h 2m 34s"
                android:textColor="#E65100"
                android:textSize="12sp"
                android:textStyle="bold"
                android:drawableStart="@drawable/ic_timer"
                android:drawablePadding="6dp"
                android:drawableTint="#E65100"
            />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Rs 4,500"
                android:textColor="#2d6a4f"
                android:textSize="18sp"
                android:textStyle="bold"
                android:drawableStart="@drawable/ic_price"
                android:drawablePadding="6dp"
                android:drawableTint="#2d6a4f"
            />


            <Button
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/bid_btn_txt"
                app:backgroundTint="@color/farm_green"
            />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>