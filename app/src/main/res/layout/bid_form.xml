<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bid_form_background"
    android:orientation="vertical"
    android:padding="@dimen/height_24">

    <View
        android:layout_width="@dimen/default_height"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="@dimen/default_margin"
        android:background="#E0E0E0" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/bid_form_header"
        android:textColor="@color/farm_green"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Current Highest Bid: Rs 4,500"
        android:textColor="#757575" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/default_margin"
        android:hint="@string/bid_form_placeholder"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxStrokeColor="@color/farm_green"
        app:hintTextColor="@color/farm_green"
        app:boxCornerRadiusTopStart="@dimen/btn_radius"
        app:boxCornerRadiusTopEnd="@dimen/btn_radius"
        app:boxCornerRadiusBottomStart="@dimen/btn_radius"
        app:boxCornerRadiusBottomEnd="@dimen/btn_radius">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etBidAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmitBid"
        android:layout_width="match_parent"
        android:layout_height="@dimen/height_50"
        android:layout_marginTop="@dimen/height_24"
        android:text="@string/bid_form_btn"
        android:textColor="@color/white"
        app:backgroundTint="@color/farm_green"
        app:cornerRadius="8dp" />
</LinearLayout>